{
  "name": "fusion-core",
  "version": "4.1.0",
  "description": "**这是基于第一性原理，为医疗级大型应用定制的 1+4+13 专职兵种大语言模型 AI 框架。**",
  "main": "index.js",
  "bin": {
    "fusion-core": "./bin/fusion-core.js",
    "fusion-router": "./bin/fusion-core-router.js",
    "fusion-init": "./bin/fusion-init.js"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.ts",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules",
    "format": "prettier --write \"**/*.{js,ts,md,json}\"",
    "prepare": "husky",
    "docs:dev": "astro dev",
    "docs:build": "astro build"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write",
      "node .claude/hooks/post-tool-use.js"
    ],
    "*.md": [
      "markdownlint --fix",
      "prettier --write",
      "node .claude/hooks/post-tool-use.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@astrojs/starlight": "^0.37.6",
    "@eslint/js": "^10.0.1",
    "astro": "^5.18.0",
    "c8": "^11.0.0",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.0",
    "markdownlint-cli": "^0.47.0",
    "prettier": "^3.8.1",
    "playwright": "^1.52.0"
  }
}
